# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://czavgpxhzhidwhsxukom.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — used only by the DocsAutomator webhook route (RLS bypass)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (speech analysis + quote review)
ANTHROPIC_API_KEY=
# Optional: pin the Sonnet-tier model. Leave unset to use the built-in default
# (claude-sonnet-4-6); if that snapshot is ever retired the app auto-resolves
# the current Sonnet-tier model. Set this to pin/bump immediately without code.
ANTHROPIC_SONNET_MODEL=

# SMTP (bid sheet emails + signature notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# DocsAutomator (contract generation + e-signature)
# API key: DocsAutomator > Settings > Workspace > API
DOCSAUTOMATOR_API_KEY=
# Automation ID of the "JanPro Services Agreement + SOW" automation
DOCSAUTOMATOR_AUTOMATION_ID_CONTRACT=
# Shared secret for the signing webhook: /api/webhooks/docsautomator?secret=...
DOCSAUTOMATOR_WEBHOOK_SECRET=
# Optional: extra recipient for signed-contract notifications (regional office)
SIGNED_CONTRACT_NOTIFY_EMAIL=

# Absolute app URL used in notification emails
NEXT_PUBLIC_APP_URL=
